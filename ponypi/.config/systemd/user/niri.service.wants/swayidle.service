[Install]
WantedBy=graphical-session.target

[Unit]
Description=idle out sway
# PartOf=graphical-session.target
PartOf=niri.service
# Before=graphical-session.target
# Requisite=graphical-session.target
After=niri.service
Requisite=niri.service

[Service]
ExecStart=/usr/bin/swayidle -w timeout 601 'niri msg action power-off-monitors' timeout 600 'swaylock -f'
Restart=on-failure
